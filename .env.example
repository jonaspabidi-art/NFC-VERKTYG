# Supabase (Project Settings -> API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Slumpa fram långa, unika värden för följande i produktion, t.ex: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
IP_HASH_SALT=change-me-to-a-long-random-string

# Cookie-namn/inställningar
DEVICE_ID_COOKIE_NAME=rr_device_id

# Valfri: sätt denna för att aktivera /superadmin/login.html (ultra-admin,
# kan skapa/redigera/ta bort restauranger). Generera med:
#   npm run hash-password -- "ditt-onskade-losenord"
SUPER_ADMIN_PASSWORD_HASH=

PORT=3000
NODE_ENV=development
